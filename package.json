{
  "name": "simsuite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first Sims content management suite built with Tauri, React, Rust, and SQLite.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "desktop:driver": "pwsh -NoProfile -File scripts/desktop/run-tauri-webdriver.ps1",
    "desktop:driver:fixtures": "pwsh -NoProfile -File scripts/desktop/run-tauri-webdriver.ps1 -UseSmokeFixtures",
    "desktop:smoke": "node scripts/desktop/desktop-smoke.mjs",
    "desktop:smoke:apply": "node scripts/desktop/desktop-smoke.mjs --include-apply"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "selenium-webdriver": "^4.41.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
