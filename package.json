{
    "name": "simsuite",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "Local-first Sims content management suite built with Tauri, React, Rust, and SQLite.",
    "scripts": {
        "dev": "vite",
        "dev:cleanup": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/dev/cleanup-dev-port.ps1",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "tauri:dev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/dev/run-tauri-dev.ps1",
        "tauri:build": "tauri build",
        "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
        "desktop:driver": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/desktop/run-tauri-webdriver.ps1",
        "desktop:driver:fixtures": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/desktop/run-tauri-webdriver.ps1 -UseSmokeFixtures",
        "desktop:smoke": "node scripts/desktop/desktop-smoke.mjs",
        "desktop:smoke:apply": "node scripts/desktop/desktop-smoke.mjs --include-apply",
        "desktop:smoke:fixtures": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/desktop/run-tauri-smoke.ps1",
        "desktop:smoke:apply:fixtures": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/desktop/run-tauri-smoke.ps1 -IncludeApply",
        "test:unit": "vitest run"
    },
    "dependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.60.2",
        "@tauri-apps/api": "^2.10.1",
        "esbuild": "0.27.7",
        "lru-cache": "^5.1.1",
        "lucide-react": "^0.577.0",
        "motion": "^12.35.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@esbuild/linux-x64": "^0.28.0",
        "@playwright/test": "^1.59.1",
        "@tanstack/react-virtual": "^3.13.24",
        "@tauri-apps/cli": "^2.10.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "jsdom": "^29.0.0",
        "playwright": "^1.58.2",
        "screenshot-desktop": "^1.15.3",
        "selenium-webdriver": "^4.41.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.0"
    },
    "pnpm": {
        "overrides": {
            "@babel/helper-compilation-targets>lru-cache": "5.1.1"
        }
    }
}
